{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-personal-scheduler/llm-output.schema.json",
  "title": "AI Personal Scheduler LLM Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "intent",
    "userRequest",
    "locale",
    "timezone",
    "mainTask",
    "subtasks",
    "schedulingConstraints",
    "meta"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "intent": {
      "type": "string",
      "enum": [
        "create_task",
        "add_subtasks",
        "auto_schedule",
        "reschedule",
        "recommend"
      ]
    },
    "userRequest": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "default": "id-ID"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Jakarta"
    },
    "mainTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "priority",
        "status"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "done"
          ]
        }
      }
    },
    "subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "notes",
          "order",
          "estimatedMinutes",
          "isFlexible"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "notes": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 300
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "estimatedMinutes": {
            "type": "integer",
            "minimum": 5,
            "maximum": 480
          },
          "isFlexible": {
            "type": "boolean"
          }
        }
      }
    },
    "estimatedDurationPerSubtask": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subtaskTitle",
          "minutes",
          "confidence"
        ],
        "properties": {
          "subtaskTitle": {
            "type": "string",
            "minLength": 1
          },
          "minutes": {
            "type": "integer",
            "minimum": 5,
            "maximum": 480
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "default": []
    },
    "schedulingConstraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deadline",
        "preferredTimeWindows",
        "fixedEvents",
        "maxDailyFocusMinutes",
        "allowWeekend"
      ],
      "properties": {
        "deadline": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "preferredTimeWindows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "day",
              "start",
              "end"
            ],
            "properties": {
              "day": {
                "type": "string",
                "enum": [
                  "monday",
                  "tuesday",
                  "wednesday",
                  "thursday",
                  "friday",
                  "saturday",
                  "sunday"
                ]
              },
              "start": {
                "type": "string",
                "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
              },
              "end": {
                "type": "string",
                "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
              }
            }
          }
        },
        "fixedEvents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "title",
              "startTime",
              "endTime"
            ],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "startTime": {
                "type": "string",
                "format": "date-time"
              },
              "endTime": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "maxDailyFocusMinutes": {
          "type": "integer",
          "minimum": 30,
          "maximum": 1440
        },
        "allowWeekend": {
          "type": "boolean"
        }
      }
    },
    "schedulePlan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subtaskTitle",
          "startTime",
          "endTime",
          "date",
          "reason"
        ],
        "properties": {
          "subtaskTitle": {
            "type": "string",
            "minLength": 1
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        }
      },
      "default": []
    },
    "reschedulePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "conflicts",
        "moves"
      ],
      "properties": {
        "trigger": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title",
            "startTime",
            "endTime"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "startTime": {
              "type": "string",
              "format": "date-time"
            },
            "endTime": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subtaskTitle",
              "oldStartTime",
              "oldEndTime"
            ],
            "properties": {
              "subtaskTitle": {
                "type": "string",
                "minLength": 1
              },
              "oldStartTime": {
                "type": "string",
                "format": "date-time"
              },
              "oldEndTime": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "moves": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subtaskTitle",
              "newStartTime",
              "newEndTime",
              "reason"
            ],
            "properties": {
              "subtaskTitle": {
                "type": "string",
                "minLength": 1
              },
              "newStartTime": {
                "type": "string",
                "format": "date-time"
              },
              "newEndTime": {
                "type": "string",
                "format": "date-time"
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "maxLength": 300
              }
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "message",
          "priority"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "next_action",
              "productivity_tip",
              "reminder"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      },
      "default": []
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "generatedAt",
        "confidence",
        "needsUserConfirmation",
        "assumptions"
      ],
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "needsUserConfirmation": {
          "type": "boolean"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "default": []
        }
      }
    }
  }
}
